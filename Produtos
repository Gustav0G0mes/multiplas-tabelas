SET SQL_SAFE_UPDATES = 0;
UPDATE pedidos
SET status = 'Concluido'
WHERE data_pedido < '2024-07-06';

SELECT data_pedido, COUNT(*) AS total_atualizados
FROM pedidos
WHERE data_pedido < '2024-07-06'
GROUP BY data_pedido
ORDER BY data_pedido;

SELECT * 
FROM pedidos
WHERE data_pedido < '2024-07-06'
ORDER BY data_pedido, id_pedido;

