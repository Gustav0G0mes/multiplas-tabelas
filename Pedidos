-- Selecionar o nome do cliente e o total de pedidos cada cliente
SELECT c.nome, COUNT(p.id_pedido) AS total_pedidos FROM clientes c JOIN pedidos p ON c.id_cliente = p.id_cliente GROUP BY c.nome;

