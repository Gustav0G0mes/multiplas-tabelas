 -- Selecionar: pedidos:  id, quantidade e data clientes: nome e email funcionarios: nome produtos: nome, preco
SELECT pe.id AS id_pedido, ip.quantidade, pe.data, c.nome AS nome_cliente, c.email, f.nome AS nome_funcionario, pr.nome AS nome_produto, pr.preco FROM pedidos pe JOIN clientes c ON pe.cliente_id = c.id JOIN funcionarios f ON pe.funcionario_id = f.id JOIN itens_pedido ip ON pe.id

 
-- Selecionar o nome dos clientes com os pedidos com status Ă¢â‚¬ËœPendenteĂ¢â‚¬â„¢ e exibir por ordem descendente de acordo com o id do pedidos
use clientes;
SELECT c.nome, p.id_pedido FROM clientes c JOIN pedidos p ON c.id_cliente = p.id_cliente WHERE p.status = 'Pendente' ORDER BY p.id_pedido DESC;
