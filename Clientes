SELECT id_cliente,
LAG(id_cliente) 
OVER (ORDER BY id_cliente) AS anterior,id_cliente - LAG(id_cliente) OVER (ORDER BY id_cliente) AS diferenca
FROM clientes
ORDER BY id_cliente;

