USE restaurante;
CREATE DATABASE IF NOT EXISTS info_produtos;
USE info_produtos;

CREATE TABLE info_produtos (
id_info INT PRIMARY KEY AUTO_INCREMENT,
id_produto INT,
ingredientes TEXT,
fornecedor VARCHAR(255),
    
CONSTRAINT fk_produto
FOREIGN KEY (id_produto) REFERENCES produtos(id_produto)
ON DELETE CASCADE
ON UPDATE CASCADE
);


CREATE TABLE IF NOT EXISTS info_produtos (
    id_info INT PRIMARY KEY AUTO_INCREMENT,
    id_produto INT,
    ingredientes TEXT,
    fornecedor VARCHAR(255),

    CONSTRAINT fk_info_produto
        FOREIGN KEY (id_produto) REFERENCES produtos(id_produto)
        ON DELETE CASCADE
        ON UPDATE CASCADE
);

